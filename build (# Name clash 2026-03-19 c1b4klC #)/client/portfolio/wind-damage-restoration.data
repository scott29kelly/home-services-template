[{"_1":2},"routes/portfolio.$slug",{"_3":4},"data",{"_5":6},"project",{"_7":8,"_9":10,"_11":12,"_13":14,"_15":16,"_17":18,"_19":20,"_21":22,"_23":24},"id",6,"slug","wind-damage-restoration","title","Wind Damage Restoration","location","Georgetown, TX","category","storm","detail","Emergency Repair","image","/images/project-6.webp","featured",true,"description","Straight-line winds from a derecho peeled back nearly a quarter of this home's roof in under 30 minutes. Our crew was on-site within four hours, installing emergency tarping to prevent further interior damage. A full roof replacement was completed the following week, and the homeowners were back in their beds within 10 days."]
