[{"_1":2},"routes/portfolio.$slug",{"_3":4},"data",{"_5":6},"project",{"_7":8,"_9":10,"_11":12,"_13":14,"_15":16,"_17":18,"_19":20,"_21":22},"id",5,"slug","siding-trim-package","title","Siding & Trim Package","location","Madison, TX","category","siding","detail","Complete Exterior","image","/images/project-5.webp","description","This two-story home needed more than just new siding — the original trim, fascia, and soffit were all rotted and pulling away from the structure. We replaced the full exterior package with LP SmartSide engineered wood siding, new PVC trim boards, and seamless aluminum fascia, fully refreshing the home's curb appeal."]
