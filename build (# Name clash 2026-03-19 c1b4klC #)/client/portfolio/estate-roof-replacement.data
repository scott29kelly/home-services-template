[{"_1":2},"routes/portfolio.$slug",{"_3":4},"data",{"_5":6},"project",{"_7":8,"_9":10,"_11":12,"_13":14,"_15":16,"_17":18,"_19":20,"_21":22},"id",9,"slug","estate-roof-replacement","title","Estate Roof Replacement","location","Tulsa, OK","category","roofing","detail","Premium Materials","image","/images/project-9.webp","description","A 5,800 sq ft estate home with multiple roof planes, skylights, and a slate tile section required a crew with specialized expertise. We replaced the asphalt field with Owens Corning Duration FLEX shingles, re-flashed all four skylights, and restored the slate section with hand-matched Vermont slate. The project was completed on schedule with a 10-year workmanship warranty."]
