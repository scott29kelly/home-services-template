[{"_1":2},"routes/portfolio.$slug",{"_3":4},"data",{"_5":6},"project",{"_7":8,"_9":10,"_11":12,"_13":14,"_15":16,"_17":18,"_19":20,"_21":22,"_23":24,"_25":26,"_27":28},"id",2,"slug","vinyl-siding-transformation","title","Vinyl Siding Transformation","location","Springfield, TX","category","siding","detail","Vinyl Siding","image","/images/project-2.webp","featured",true,"description","Faded, warped wood siding was deteriorating and driving up energy bills for this 1980s ranch home. We removed the original wood, added a moisture barrier, and installed James Hardie fiber cement siding in Aged Pewter. The owners reported a noticeable drop in heating costs within the first month.","beforeImage","/images/before-after-2-before.webp","afterImage","/images/before-after-2-after.webp"]
