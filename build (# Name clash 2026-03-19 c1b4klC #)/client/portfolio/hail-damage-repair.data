[{"_1":2},"routes/portfolio.$slug",{"_3":4},"data",{"_5":6},"project",{"_7":8,"_9":10,"_11":12,"_13":14,"_15":16,"_17":18,"_19":20,"_21":22,"_23":24},"id",3,"slug","hail-damage-repair","title","Hail Damage Repair","location","Riverside, TX","category","storm","detail","Insurance Claim","image","/images/project-3.webp","featured",true,"description","A severe hailstorm left over 400 impact marks across this homeowner's roof, gutters, and siding. We handled the full insurance documentation process, meeting with the adjuster on-site to ensure a fair settlement. The complete restoration — new roof, gutters, and siding — was finished within the approved claim budget."]
