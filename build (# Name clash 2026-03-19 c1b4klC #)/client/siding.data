[{"_1":2},"routes/service-page/siding",{"_3":4},"data",{"_5":6},"service",{"_7":8,"_9":10,"_11":10,"_12":13,"_14":15,"_24":25,"_30":31,"_34":35,"_119":120},"slug","siding","name","Siding","navLabel","icon","PanelLeft","hero",{"_16":17,"_18":19,"_20":21,"_22":23},"backgroundImage","/images/siding-hero.webp","headline","Transform Your Home with","highlightText","New Siding","subhead","Beautiful, durable vinyl siding that protects your home and increases curb appeal. Expert installation with lasting results.","meta",{"_26":27,"_28":29},"title","Siding Services","description","Transform your home with beautiful, durable vinyl siding. Expert installation with lasting results. Free estimates.","overview",{"_32":17,"_28":33},"image","Vinyl siding in multiple styles – horizontal lap, Dutch lap, board & batten, shake. Durable, energy-efficient installation.","sections",[36,64,90],{"_37":38,"_26":39,"_40":41,"_42":43,"_44":45,"_46":47},"type","iconGrid","Why Choose New Siding?","subtitle","Upgrade your home's exterior with benefits that last for decades.","columns",4,"colorScheme","blue","cards",[48,52,56,60],{"_12":49,"_26":50,"_28":51},"Palette","Enhanced Curb Appeal","Transform your home's look with modern colors and styles.",{"_12":53,"_26":54,"_28":55},"DollarSign","Increased Value","Siding replacement offers one of the best returns on investment.",{"_12":57,"_26":58,"_28":59},"Thermometer","Energy Efficiency","Insulated siding helps reduce heating and cooling costs.",{"_12":61,"_26":62,"_28":63},"Wrench","Low Maintenance","No painting required – just occasional cleaning.",{"_37":65,"_66":67,"_26":68,"_42":69,"_46":70},"cardGrid","bg","surface","Our Siding Services",2,[71,81],{"_26":72,"_32":73,"_28":74,"_75":76},"Vinyl Siding Installation","/images/vinyl-siding.webp","Our most popular option. Vinyl siding is durable, affordable, and available in countless colors and styles to match any home.","features",[77,78,79,80],"Wide color selection","Weather resistant","Fade resistant","25+ year warranties",{"_26":82,"_32":83,"_28":84,"_75":85},"Siding Repair","/images/siding-repair.webp","Storm damage or wear and tear? We can repair or replace damaged sections to restore your home's protection and appearance.",[86,87,88,89],"Storm damage repair","Section replacement","Color matching","Insurance claims assistance",{"_37":91,"_26":92,"_40":93,"_46":94},"styleGallery","Siding Styles & Options","Find the perfect look for your home.",[95,99,103,107,111,115],{"_26":96,"_32":97,"_28":98},"Horizontal Lap Siding","/images/siding-horizontal.webp","The classic American look. Clean horizontal lines that work with any architectural style.",{"_26":100,"_32":101,"_28":102},"Dutch Lap Siding","/images/siding-dutch.webp","A decorative groove adds shadow lines and visual interest to your home's exterior.",{"_26":104,"_32":105,"_28":106},"Board & Batten","/images/siding-board-batten.webp","Vertical siding with a farmhouse-inspired look. Perfect for accent areas or full coverage.",{"_26":108,"_32":109,"_28":110},"Shake & Shingle","/images/siding-shake.webp","The charm of cedar shakes without the maintenance. Great for gables and accent areas.",{"_26":112,"_32":113,"_28":114},"Scallop Siding","/images/siding-scallop.webp","Decorative scalloped edges for Victorian and cottage-style homes.",{"_26":116,"_32":117,"_28":118},"Insulated Siding","/images/siding-insulated.webp","Built-in foam backing increases energy efficiency and reduces outside noise.","faqs",{"_26":121,"_122":123},"Siding FAQs","items",[124,129,132,135],{"_125":126,"_127":128},"question","How long does vinyl siding last?","answer","Quality vinyl siding can last 25-40 years or more with proper installation. Most manufacturers offer warranties of 25+ years, and some offer lifetime limited warranties.",{"_125":130,"_127":131},"How do I maintain vinyl siding?","Vinyl siding is virtually maintenance-free. An occasional rinse with a garden hose is usually all that's needed. For tougher dirt, a soft brush and mild detergent work well.",{"_125":133,"_127":134},"Can siding be installed over existing siding?","In some cases, yes. However, we typically recommend removing old siding to inspect the underlying structure for damage or rot. This ensures the best long-term results.",{"_125":136,"_127":137},"Will insurance cover storm-damaged siding?","Yes, storm damage to siding is typically covered by homeowner's insurance. We specialize in insurance claims and will help you document the damage and work with your adjuster."]
