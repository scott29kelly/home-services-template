[{"_1":2},"routes/service-page/storm-damage",{"_3":4},"data",{"_5":6},"service",{"_7":8,"_9":10,"_11":12,"_13":14,"_15":16,"_33":34,"_38":39,"_42":43,"_110":111},"slug","storm-damage","name","Storm Damage Repair","navLabel","Storm Repair","icon","CloudLightning","hero",{"_17":18,"_19":20,"_21":22,"_23":24,"_25":26,"_31":32},"backgroundImage","/images/storm-damage-hero.webp","headline","Storm Damage?","highlightText","We're Here to Help.","subhead","Fast response storm damage repair. We handle the insurance claims process so you don't have to stress.","primaryCTA",{"_27":28,"_29":30},"text","Request Free Inspection","href","/contact","showEmergencyPhone",true,"meta",{"_35":10,"_36":37},"title","description","Fast response storm damage repair. We handle insurance claims so you don't have to stress. Free inspections.","overview",{"_40":18,"_36":41},"image","Fast response for hail, wind, and tree damage. Full support through the insurance claims process.","sections",[44,51,74,76],{"_45":46,"_27":47,"_48":49,"_50":30},"type","emergencyBanner","Had a recent storm? Don't wait – water damage gets worse over time.","ctaText","Get Inspected Today","ctaHref",{"_45":52,"_35":53,"_54":55,"_56":57,"_58":59,"_60":61},"iconGrid","Types of Storm Damage We Repair","subtitle","We're experts in identifying and repairing all types of storm damage to your home.","columns",3,"colorScheme","orange","cards",[62,66,70],{"_13":63,"_35":64,"_36":65},"CloudHail","Hail Damage","Hail can crack, dent, and dislodge shingles – often in ways that aren't visible from the ground. We identify all damage for your claim.",{"_13":67,"_35":68,"_36":69},"Wind","Wind Damage","High winds can lift, tear, or completely remove shingles. We assess wind damage patterns and document everything.",{"_13":71,"_35":72,"_36":73},"TreePine","Fallen Trees & Debris","Tree limbs and flying debris can cause serious structural damage. We coordinate repairs and work with your insurance.",{"_45":75},"processTimeline",{"_45":77,"_35":78,"_54":79,"_80":81,"_48":94,"_50":30,"_95":96},"trustSection","Why Homeowners Trust Us for Insurance Claims","Dealing with storm damage is stressful. Dealing with insurance companies can be even worse. That's why we handle the heavy lifting for you.","trustPoints",[82,85,88,91],{"_35":83,"_36":84},"We're Your Advocate","We work for YOU, not the insurance company. Our goal is to ensure you get fair compensation.",{"_35":86,"_36":87},"Thorough Documentation","We document every bit of damage – even what's not visible from the ground – so nothing gets missed.",{"_35":89,"_36":90},"Adjuster Meeting","We meet with your adjuster on-site to walk through the damage and ensure proper assessment.",{"_35":92,"_36":93},"No Pressure","Free inspections with no obligation. We'll give you an honest assessment – even if you don't have damage.","Schedule Free Inspection","sidebar",{"_35":97,"_13":98,"_99":100,"_108":109},"Signs You May Have Storm Damage","AlertTriangle","items",[101,102,103,104,105,106,107],"Missing, cracked, or curling shingles","Dents in gutters, downspouts, or vents","Granules accumulating in gutters","Dented or damaged siding","Water stains on ceilings or walls","Leaks in your attic after rain","Neighbors getting roof work done","footnote","Storm damage isn't always visible from the ground. A professional inspection is the only way to know for sure.","faqs",{"_35":112,"_99":113},"Storm Damage & Insurance FAQs",[114,119,122,125,128],{"_115":116,"_117":118},"question","How soon should I get my roof inspected after a storm?","answer","As soon as possible. Storm damage can lead to leaks and further damage if left unaddressed. Most insurance policies also have time limits for filing claims, so don't wait.",{"_115":120,"_117":121},"Do I have to pay for the inspection?","No – our storm damage inspections are completely free with no obligation. We'll provide an honest assessment of whether you have damage worth filing a claim for.",{"_115":123,"_117":124},"Will my insurance rates go up if I file a claim?","Storm damage claims are typically \"Acts of God\" and don't affect your rates the same way an at-fault claim might. However, policies vary, so check with your insurance agent.",{"_115":126,"_117":127},"What if my claim is denied?","Don't give up. Claims are sometimes denied initially but can be appealed with proper documentation. We can help you understand your options and supplement your claim if needed.",{"_115":129,"_117":130},"How much will I have to pay out of pocket?","Typically, your only out-of-pocket cost is your insurance deductible. We work directly with your insurance to ensure the approved amount covers the cost of quality repairs."]
