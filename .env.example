# ── Vercel Speed Insights ──────────────────────────────────
# Set to 'true' to enable real-user monitoring on Vercel deployments.
# Has no effect on non-Vercel hosts.
VITE_VERCEL_SPEED_INSIGHTS=false

# ── API Configuration ──────────────────────────────────────
# Chat API endpoint (defaults to /api/chat in development)
# VITE_API_URL=https://your-api.example.com

# ── API Backend (server-side only, not exposed to browser) ─
# GROQ_API_KEY=your-groq-api-key
# ANTHROPIC_API_KEY=your-anthropic-api-key
# ALLOWED_ORIGIN=https://your-domain.com
